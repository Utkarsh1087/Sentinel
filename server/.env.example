# Sentinel Server Configuration Template
PORT=5000

# PostgreSQL (Metadata & Projects)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:password@localhost:5432/sentinel

# InfluxDB v2 (Time-Series Metrics)
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influxdb-token-here
INFLUX_ORG=your-org-name
INFLUX_BUCKET=your-bucket-name

# Redis (Ingestion Cache & BullMQ Alerting)
REDIS_URL=redis://localhost:6379

# Security
# Random string for signing JWT tokens
JWT_SECRET=your-random-secret-key-change-this

# AI Diagnostics (Optional)
# Supports direct Gemini API or OpenRouter
GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
